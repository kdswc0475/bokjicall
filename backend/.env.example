# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration (PostgreSQL)
# For Supabase/Neon: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/bokjicall?schema=public"

# Security
# Comma-separated list of allowed origins
ALLOWED_ORIGINS="http://localhost:5173,https://your-app.vercel.app"

# External APIs
# Get your key from data.go.kr
PUBLIC_DATA_API_KEY=your_actual_api_key_here
CENTRAL_WELFARE_API=http://apis.data.go.kr/B554287/NationalWelfareInformationsV001
